env HOME=$WORK/.home
exec cue_user_funcs export --shim .
cmp stdout expected_shim.go

exec cue_user_funcs mod tidy
exec cue_user_funcs export .
cmp stdout expected.json

-- cue.mod/module.cue --
module: "test.example"
language: {
	version: "v0.16.0"
}
-- example.cue --
@extern(inject)

package example

#NonZero: _ @inject(name="github.com/cue-exp/cue_user_funcs@v0.0.0-20260309063023-5ad5b30fc367/text/template.NonZero")

trueString:  #NonZero("hello")
falseString: #NonZero("")
trueInt:     #NonZero(42)
falseInt:    #NonZero(0)
trueBool:    #NonZero(true)
falseBool:   #NonZero(false)
trueList:    #NonZero([1, 2])
falseList:   #NonZero([])
trueMap:     #NonZero({a: 1})
falseMap:    #NonZero({})
-- expected_shim.go --
package main

import (
	"cuelang.org/go/cue"
	"cuelang.org/go/cue/cuecontext"
	pkg1 "github.com/cue-exp/cue_user_funcs/text/template"
)

func registerAll(j *cuecontext.Injector) {
	j.Register("github.com/cue-exp/cue_user_funcs@v0.0.0-20260309063023-5ad5b30fc367/text/template.NonZero", cue.PureFunc1(func(a0 any) (bool, error) {
		return pkg1.NonZero(a0), nil
	}, cue.Name("github.com/cue-exp/cue_user_funcs@v0.0.0-20260309063023-5ad5b30fc367/text/template.NonZero")))
}
-- expected.json --
{
    "falseBool": false,
    "falseInt": false,
    "falseList": false,
    "falseMap": false,
    "falseString": false,
    "trueBool": true,
    "trueInt": true,
    "trueList": true,
    "trueMap": true,
    "trueString": true
}
